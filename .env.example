# CornField — Docker deployment config (Option 2: NAS / home server).
# Copy this file to ".env" and adjust the paths for your machine:
#   cp .env.example .env
# ".env" is gitignored, so your settings stay out of version control.

# Host folder where CornField stores its database, thumbnails, and seek previews.
# Use a folder on the server's OWN local filesystem (not a remote SMB/NFS mount),
# so SQLite file locking stays reliable.
CORNFIELD_DATA_PATH=./data

# Host path to your video library. It is mounted read-only at /library inside the
# container; set "Library Folder Path" in Settings to /library after starting.
CORNFIELD_LIBRARY_PATH=/share/Videos

# Host port to expose the web UI on (the app always listens on 4300 internally).
CORNFIELD_PORT=4300
